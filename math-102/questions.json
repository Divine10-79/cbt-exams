  "duration_minutes": 45,
  "questions": [
    {"id":"q1","text":"Compute $\\lim_{x\\to 0} \\frac{\\sin x}{x}$.","options":["0","1","Does not exist","\\infty"],"answer":1,"explanation":"Standard limit: $\\lim_{x\\to0}\\sin x/x=1$."},
    {"id":"q2","text":"Find $\\lim_{x\\to\\infty} \\frac{2x^2+3x}{x^2-1}$.","options":["2","1","0","\\infty"],"answer":0,"explanation":"Divide numerator and denominator by $x^2$: limit is 2."},
    {"id":"q3","text":"If $f(x)=x^3-3x$, find $f'(x)$.","options":["3x^2-3","3x^2","x^2-3","None of the above"],"answer":0,"explanation":"Differentiate termwise: $f'(x)=3x^2-3$."},
    {"id":"q4","text":"Differentiate $y=\\ln(2x)$ with respect to $x$.","options":["1/(2x)","2/x","1/x","1"],"answer":2,"explanation":"$d/dx\\ln(2x)=1/(2x)\\cdot 2=1/x$."},
    {"id":"q5","text":"Find the derivative of $y=\\sin^2 x$ (i.e. $(\\sin x)^2$).","options":["2\\sin x\\cos x","\\cos^2 x","\\sin x","-\\sin x"],"answer":0,"explanation":"Use chain rule: $2\\sin x\\cdot\\cos x$."},
    {"id":"q6","text":"Compute $\\lim_{x\\to 0} \\frac{e^x-1}{x}$.","options":["0","1","e","Does not exist"],"answer":1,"explanation":"Standard limit: derivative of $e^x$ at 0 is 1."},
    {"id":"q7","text":"If $g(x)=\\frac{1}{x}$, find $g'(x)$.","options":["-1/x^2","1/x^2","-1/x","1"],"answer":0,"explanation":"$d/dx(x^{-1})=-x^{-2}=-1/x^2$."},
    {"id":"q8","text":"Let $h(x)=(x^2+1)(x-3)$. Find $h'(x)$.","options":["3x^2-6","3x^2-4","3x^2+?","2x(x-3)+(x^2+1)"],"answer":3,"explanation":"Product rule: $2x(x-3)+(x^2+1)$."},
    {"id":"q9","text":"Compute $\\int_0^1 3x^2  dx$.","options":["1","3","2","1/3"],"answer":0,"explanation":"Antiderivative $x^3$, evaluate 0..1 gives 1."},
    {"id":"q10","text":"Evaluate $\\int e^{2x}  dx$.","options":["e^{2x}+C","\\frac{1}{2}e^{2x}+C","2e^{2x}+C","\\ln|e^{2x}|+C"],"answer":1,"explanation":"Antiderivative is $e^{2x}/2 + C$."},
    {"id":"q11","text":"Find the derivative of $y=\\arctan(x)$.","options":["1/(1+x^2)","1/(1-x^2)","\\cos x","\\sec^2 x"],"answer":0,"explanation":"$d/dx\\arctan x=1/(1+x^2)$."},
    {"id":"q12","text":"Compute $\\lim_{x\\to 1} \\frac{x^3-1}{x-1}$.","options":["3","1","0","\\infty"],"answer":0,"explanation":"Factor numerator: (x-1)(x^2+x+1) -> plug x=1 gives 3."},
    {"id":"q13","text":"Differentiate $y=\\sqrt{x}$.","options":["1/(2\\sqrt{x})","1/(\\sqrt{x})","2\\sqrt{x}","-1/(2\\sqrt{x})"],"answer":0,"explanation":"$d/dx x^{1/2}=(1/2)x^{-1/2}=1/(2\\sqrt{x})$."},
    {"id":"q14","text":"If $f(x)=\\ln(x^2+1)$, find $f'(x)$.","options":["2x/(x^2+1)","1/(x^2+1)","2/(x^2+1)","x/(x^2+1)"],"answer":0,"explanation":"Chain rule: derivative is $2x/(x^2+1)$."},
    {"id":"q15","text":"Evaluate $\\int_0^{\\pi} \\sin x  dx$.","options":["0","2","1","-2"],"answer":1,"explanation":"Antiderivative is $-\\cos x$, so -cos(pi)+cos(0)=2."},
    {"id":"q16","text":"Compute $\\lim_{x\\to 0} \\frac{1-\\cos x}{x^2}$.","options":["1/2","0","1","\\infty"],"answer":0,"explanation":"Use series: 1-cos x ~ x^2/2 so limit 1/2."},
    {"id":"q17","text":"Differentiate $y=\\tan x$.","options":["\\sec^2 x","\\tan^2 x","\\cos^2 x","1/\\cos x"],"answer":0,"explanation":"$d/dx\\tan x=\\sec^2 x$."},
    {"id":"q18","text":"If $f(x)=x^x$, find $\\frac{d}{dx}f(x)$ (for x>0).","options":["x^x(\\ln x+1)","x^{x-1}","x^x\\ln x","x^x/x"],"answer":0,"explanation":"Differentiate via log: d/dx x^x = x^x(\\ln x+1)."},
    {"id":"q19","text":"Evaluate $\\int x\\cos x  dx$.","options":["x\\sin x+\\cos x +C","x\\sin x-\\cos x +C","\\sin x+ C","-x\\cos x +C"],"answer":0,"explanation":"Integration by parts: u=x, dv=cos x dx -> x\\sin x - \\int\\sin x dx = x\\sin x+\\cos x +C."},
    {"id":"q20","text":"Compute $\\lim_{x\\to 0^+} x\\ln x$.","options":["0","-\\infty","\\infty","1"],"answer":0,"explanation":"x ln x -> 0 as x->0^+. Use substitution x=e^{-t}."},
    {"id":"q21","text":"Find the derivative of $y=\\frac{x^2+1}{x}$.","options":["1-1/x^2","1+1/x^2","2x-1/x","2x+1/x^2"],"answer":0,"explanation":"Simplify to x+1/x then derivative is 1-1/x^2."},
    {"id":"q22","text":"Evaluate $\\int_1^2 \\frac{1}{x}  dx$.","options":["\\ln 2","1/2","2","\\ln(1)"],"answer":0,"explanation":"Integral of 1/x is ln x, evaluate gives ln 2."},
    {"id":"q23","text":"If $f(x)=e^{3x}$, compute $f''(x)$.","options":["9e^{3x}","3e^{3x}","e^{3x}","6e^{3x}"],"answer":0,"explanation":"Each derivative multiplies by 3: second derivative 9e^{3x}."},
    {"id":"q24","text":"Compute $\\lim_{x\\to 0} \\frac{\\tan x - x}{x^3}$.","options":["1/3","0","1","-1/3"],"answer":0,"explanation":"Use series expansion: tan x = x + x^3/3 + ..., so limit = 1/3."},
    {"id":"q25","text":"Differentiate $y=\\ln(\\sin x)$ for x in (0,\\pi).","options":["\\cot x","\\tan x","\\csc x","-\\cot x"],"answer":0,"explanation":"d/dx ln(sin x)=cos x/sin x = cot x."},
    {"id":"q26","text":"Evaluate $\\int 2x e^{x^2}  dx$.","options":["e^{x^2}+C","2e^{x^2}+C","x e^{x^2}+C","\\frac{1}{2}e^{x^2}+C"],"answer":0,"explanation":"Substitute u=x^2, du=2x dx, integral is e^{x^2}+C."},
    {"id":"q27","text":"Find derivative of $y=\\frac{d}{dx} (\\arcsin x)$.","options":["1/\\sqrt{1-x^2}","1/(1-x^2)","1/\\sqrt{1+x^2}","\\sqrt{1-x^2}"],"answer":0,"explanation":"d/dx arcsin x = 1/\\sqrt{1-x^2}."},
    {"id":"q28","text":"Compute $\\int_0^{\\pi/2} \\sin^2 x  dx$.","options":["\\pi/4","\\pi/2","1","0"],"answer":0,"explanation":"Average value over quarter period: integral equals pi/4."},
    {"id":"q29","text":"If $f(x)=x^4-2x^2$, find critical points solving f'(x)=0.","options":["x=0, x=\u00b11","x=0 only","x=\u00b1","x=\u00b12"],"answer":0,"explanation":"f'=4x^3-4x=4x(x^2-1)=0 => x=0, +/-1."},
    {"id":"q30","text":"Evaluate $\\lim_{x\\to 0} \\frac{e^{x}-1-x}{x^2}$.","options":["1/2","1","0","-1/2"],"answer":0,"explanation":"Series e^x=1+x+x^2/2+..., numerator ~ x^2/2 so limit 1/2."},
    {"id":"q31","text":"Differentiate implicitly: if $x^2+y^2=1$, find $dy/dx$.","options":["-x/y","y/x","x/y","-y/x"],"answer":0,"explanation":"Differentiate: 2x+2y y' =0 => y'=-x/y."},
    {"id":"q32","text":"Compute $\\int \\frac{1}{1+x^2}  dx$.","options":["\\arctan x + C","\\ln(1+x^2)+C","\\arcsin x + C","\\sqrt{1+x^2}+C"],"answer":0,"explanation":"Standard integral gives arctan x + C."},
    {"id":"q33","text":"Find the second derivative of $y=\\sin x$.","options":["-\\sin x","\\sin x","-\\cos x","\\cos x"],"answer":0,"explanation":"First derivative cos x, second derivative -sin x."},
    {"id":"q34","text":"Evaluate $\\lim_{x\\to 2} \\frac{x^2-4}{x-2}$.","options":["4","2","0","\\infty"],"answer":0,"explanation":"Factor gives (x-2)(x+2)/(x-2) -> plug 2 gives 4."},
    {"id":"q35","text":"Differentiate $y=\\ln(\\tan x)$.","options":["\\sec^2 x / \\tan x","\\cot x","\\tan x","1/\\sin x"],"answer":0,"explanation":"d/dx ln(tan x)=sec^2 x / tan x = 1/(sin x cos x)."},
    {"id":"q36","text":"Compute $\\int x^2 \\ln x  dx$.","options":["\\frac{x^3}{3}\\ln x -\\frac{x^3}{9}+C","\\frac{x^3}{3}\\ln x + C","x^3\\ln x +C","\\frac{x^3}{9}\\ln x +C"],"answer":0,"explanation":"Integration by parts: u=ln x, dv=x^2 dx gives result shown."},
    {"id":"q37","text":"If $f(x)=\\frac{1}{2}x^2$, find the linear approximation at x=1 for x=1.1 (approximate value).","options":["0.6","0.5","0.605","0.61"],"answer":0,"explanation":"Linearization at a=1: L(x)=f(1)+f'(1)(x-1)=0.5+1*(0.1)=0.6."},
    {"id":"q38","text":"Compute $\\lim_{x\\to 0} \\frac{\\sin 2x}{x}$.","options":["2","1","0","\\infty"],"answer":0,"explanation":"sin(2x)/(x)=2*(sin 2x)/(2x)->2*1=2."},
    {"id":"q39","text":"Find derivative of $y=\\frac{e^x}{x}$.","options":["(xe^x-e^x)/x^2","e^x/x^2","e^x(1-1/x)/x","e^x+1/x"],"answer":0,"explanation":"Quotient rule: (x e^x - e^x)/x^2 = e^x(x-1)/x^2."},
    {"id":"q40","text":"Evaluate $\\int_0^1 x^3  dx$.","options":["1/4","1/3","1/2","1/5"],"answer":0,"explanation":"Antiderivative x^4/4, evaluate gives 1/4."},
    {"id":"q41","text":"If $f(x)=\\sin(x^2)$, find $f'(x)$.","options":["2x\\cos(x^2)","\\cos x^2","2\\sin x \\cos x","x\\cos x"],"answer":0,"explanation":"Chain rule: derivative of sin(u) is cos(u) u' where u=x^2 gives 2x cos(x^2)."},
    {"id":"q42","text":"Compute $\\lim_{x\\to 0} \\frac{\\sqrt{1+x}-1}{x}$.","options":["1/2","1","0","-1/2"],"answer":0,"explanation":"Use series or multiply conj.: limit is 1/2."},
    {"id":"q43","text":"Differentiate $y=\\sinh x$ (hyperbolic sine).","options":["\\cosh x","\\sinh x","\\tanh x","1/\\cosh x"],"answer":0,"explanation":"d/dx sinh x = cosh x."},
    {"id":"q44","text":"Evaluate $\\int \\frac{1}{\\sqrt{1-x^2}}  dx$.","options":["\\arcsin x + C","\\arccos x + C","\\ln|x+\\sqrt{1-x^2}| +C","\\arctan x +C"],"answer":0,"explanation":"Standard antiderivative is arcsin x + C."},
    {"id":"q45","text":"Find $\\lim_{x\\to 0} \\frac{\\ln(1+x)}{x}$.","options":["1","0","\\infty","1/2"],"answer":0,"explanation":"Derivative of ln(1+x) at 0 is 1."},
    {"id":"q46","text":"Differentiate $y= x^x$ at x=1; what is $y'(1)$?","options":["1","2","0","e"],"answer":0,"explanation":"General derivative x^x(ln x +1); at x=1 gives 1*(0+1)=1."},
    {"id":"q47","text":"Compute $\\int_0^{1} \\frac{1}{1+x^2}  dx$.","options":["\\pi/4","\\pi/2","1/2","1"],"answer":0,"explanation":"Arctan(1)-arctan(0)=\\pi/4."},
    {"id":"q48","text":"If $f(x)=x^3-6x^2+9x$, find local minima/maxima via second derivative test at x=1,3.","options":["x=1 local max, x=3 local min","x=1 local min, x=3 local max","both minima","both maxima"],"answer":0,"explanation":"Compute f'=3x^2-12x+9 -> roots x=1,3; f''=6x-12 so f''(1)=-6 (max), f''(3)=6 (min)."},
    {"id":"q49","text":"Evaluate the improper integral $\\int_1^{\\infty} \\frac{1}{x^2}  dx$.","options":["1","0","\\infty","1/2"],"answer":0,"explanation":"Integral is [ -1/x ]_1^{\\infty} = 1 (since -1/\\infty +1 =1)."},
    {"id":"q50","text":"Which of the following functions is continuous everywhere?","options":["x^2","1/x","\\tan x","\\ln x"],"answer":0,"explanation":"x^2 is a polynomial, continuous for all real x; others have discontinuities or restricted domains."}
  ]
}
